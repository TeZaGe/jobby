# URL de connexion à la base de données locale (Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/job_crm?schema=public"

# URL de connexion pour le déploiement de production (ex: Neon ou Supabase)
# DATABASE_URL="postgresql://user:password@neon-host:5432/job_crm?sslmode=require"

# Prochain secret pour l'authentification NextAuth.js
# Générer avec : openssl rand -base64 33
NEXTAUTH_SECRET="votre_secret_nextauth_ici"
NEXTAUTH_URL="http://localhost:3000"

# URL de l'API publique (utilisée par l'extension et le client)
NEXT_PUBLIC_API_URL="http://localhost:3000"
